# Required — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default model via OpenRouter. Swap to any supported model string.
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Turso database (remote LibSQL — required for Vercel/serverless)
# Create: turso db create collected
# URL:    turso db show collected --url
# Token:  turso db tokens create collected
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# Email magic link (Resend) — get key from https://resend.com/api-keys
AUTH_RESEND_KEY=

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Base URL for NextAuth callbacks
NEXTAUTH_URL=http://localhost:3000

# Optional — for Google OAuth (leave blank to use email magic link only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
