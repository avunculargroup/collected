# Required — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default model via OpenRouter. Swap to any supported model string.
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Local SQLite database path
DATABASE_URL=file:collected.db

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Base URL for NextAuth callbacks
NEXTAUTH_URL=http://localhost:3000

# Optional — for Google OAuth (leave blank to use email magic link only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
